  {
    "version": "1.0",
    "ai": {
      "provider": "openai",
      "model": "grok-4.1",
      "base_url": "https://api.amux.ai/v1",
      "api_key_env": "OPENAI_API_KEY",
      "temperature": 0.3,
      "max_tokens": 4096,
      "throttle_sec": 1,
      "analysis_concurrency": 2,
      "enrichment_concurrency": 2,
      "languages": ["zh"]
    },
    "email": {
      "enabled": false,
      "smtp_server": "smtp.qq.com",
      "smtp_port": 465,
      "imap_server": "imap.qq.com",
      "imap_port": 993,
      "email_address": "xxx@qq.com",
      "sender_name": "Horizon Daily",
      "subscribe_keyword": "SUBSCRIBE",
      "unsubscribe_keyword": "UNSUBSCRIBE"
    },
    "sources": {
      "github": [
        {
          "type": "repo_releases",
          "owner": "astral-sh",
          "repo": "uv",
          "enabled": true
        },
        {
          "type": "repo_releases",
          "owner": "anthropics",
          "repo": "claude-code",
          "enabled": true
        }
      ],
      "hackernews": {
        "enabled": true,
        "fetch_top_stories": 30,
        "min_score": 150
      },
      "rss": [
        {
          "name": "Simon Willison (AI)",
          "url": "https://simonwillison.net/atom/everything/",
          "enabled": true,
          "category": "ai-tools"
        },
        {
          "name": "OpenAI Blog",
          "url": "https://openai.com/news/rss.xml",
          "enabled": true,
          "category": "ai-news"
        },
        {
          "name": "Anthropic News",
          "url": "https://www.anthropic.com/news/rss.xml",
          "enabled": true,
          "category": "ai-news"
        },
        {
          "name": "机器之心",
          "url": "https://www.jiqizhixin.com/rss",
          "enabled": true,
          "category": "ai-china"
        }
      ],
      "reddit": {
        "enabled": true,
        "subreddits": [
          {
            "subreddit": "MachineLearning",
            "enabled": true,
            "sort": "hot",
            "time_filter": "day",
            "fetch_limit": 15,
            "min_score": 50
          },
          {
            "subreddit": "LocalLLaMA",
            "enabled": true,
            "sort": "hot",
            "time_filter": "day",
            "fetch_limit": 15,
            "min_score": 50
          }
        ],
        "users": [],
        "fetch_comments": 5
      },
      "twitter": {
        "enabled": false,
        "users": [],
        "fetch_limit": 0,
        "fetch_reply_text": false,
        "max_replies_per_tweet": 0,
        "max_tweets_to_expand": 0,
        "reply_min_likes": 0
      },
      "openbb": {
        "enabled": false,
        "fetch_filings": false,
        "filings_provider": "sec",
        "watchlists": []
      },
      "ossinsight": {
        "enabled": true,
        "period": "past_24_hours",
        "languages": ["All", "Python", "TypeScript"],
        "keywords": [],
        "min_stars": 50,
        "max_items": 20
      }
    },
    "filtering": {
      "ai_score_threshold": 5.0,
      "time_window_hours": 48
    },
    "webhook": {
      "enabled": false,
      "url_env": "HORIZON_WEBHOOK_URL",
      "delivery": "summary",
      "overview_position": "first",
      "platform": "generic",
      "layout": "markdown",
      "fallback_layout": "markdown",
      "languages": null,
      "request_body": {},
      "headers": ""
    }
  }
